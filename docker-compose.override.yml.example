# Surcharge locale pour le développement — NE PAS COMMITER
# Copier ce fichier : cp docker-compose.override.yml.example docker-compose.override.yml
#
# Prérequis : avoir les repos clonés dans le même dossier parent que healthai-infra :
#   ../healthai-api/        (NestJS backend)
#   ../healthai-admin/      (Next.js admin dashboard)
#   ../healthai-etl/        (FastAPI ETL)
#   ../healthai-web/        (optionnel, M3+)
#   ../healthai-ai/         (FastAPI gateway IA + vision + workout)
#
# Utilisation : docker compose up --build -d

services:
  healthai-api:
    build:
      context: ../healthai-api
      dockerfile: Dockerfile
    image: healthai-api:local
    ports:
      - "3001:3001"

  healthai-etl:
    build:
      context: ../healthai-etl
      dockerfile: Dockerfile
    image: healthai-etl:local
    ports:
      - "8000:8000"
    volumes:
      - ../healthai-etl/data:/app/data
      - ../healthai-etl/logs:/app/logs

  healthai-admin:
    build:
      context: ../healthai-admin
      dockerfile: Dockerfile
      args:
        NEXT_PUBLIC_USE_MOCK: "false"
        NEXT_PUBLIC_NESTJS_URL: http://localhost:3001
        NEXT_PUBLIC_API_KEY: ${NEXT_PUBLIC_API_KEY:-}
        NEXT_PUBLIC_CLIENT_ID: ${NEXT_PUBLIC_CLIENT_ID:-healthai-admin-front}
        NEXT_PUBLIC_FASTAPI_URL: http://localhost:8000
        NEXT_PUBLIC_METABASE_URL: http://localhost:3002
    image: healthai-admin:local
    ports:
      - "3000:3000"

  # healthai-web:
  #   build:
  #     context: ../healthai-web
  #     dockerfile: Dockerfile
  #   image: healthai-web:local
  #   ports:
  #     - "3001:3000"

  # ============================================================================
  # Stack IA — build depuis ../healthai-ai/
  # ----------------------------------------------------------------------------
  # Important : le contexte de build est la RACINE de healthai-ai (et non
  # un sous-dossier), car chaque Dockerfile copie aussi healthai-common (path
  # dependency uv). Le `dockerfile` pointe vers le bon sous-dossier.
  # ============================================================================
  healthai-ai-gateway:
    build:
      context: ../healthai-ai
      dockerfile: healthai-api/Dockerfile
    image: healthai-ai-gateway:local

  healthai-vision:
    build:
      context: ../healthai-ai
      dockerfile: healthai-vision/Dockerfile
    image: healthai-vision:local

  healthai-workout:
    build:
      context: ../healthai-ai
      dockerfile: healthai-workout/Dockerfile
    image: healthai-workout:local
