# Surcharge locale pour le développement — NE PAS COMMITER
# Copier ce fichier : cp docker-compose.override.yml.example docker-compose.override.yml
#
# Prérequis : avoir les repos clonés dans le même dossier parent que healthai-infra :
#   ../healthai-api/
#   ../healthai-admin/
#   ../healthai-etl/
#   ../healthai-web/       (optionnel, M3+)
#
# Utilisation : docker compose up --build -d

services:
  healthai-api:
    build:
      context: ../healthai-api
      dockerfile: Dockerfile
    image: healthai-api:local
    ports:
      - "3001:3001"

  healthai-etl:
    build:
      context: ../healthai-etl
      dockerfile: Dockerfile
    image: healthai-etl:local
    ports:
      - "8000:8000"
    volumes:
      - ../healthai-etl/data:/app/data
      - ../healthai-etl/logs:/app/logs

  healthai-admin:
    build:
      context: ../healthai-admin
      dockerfile: Dockerfile
      args:
        NEXT_PUBLIC_USE_MOCK: "false"
        NEXT_PUBLIC_NESTJS_URL: http://localhost:3001
        NEXT_PUBLIC_API_KEY: ${NEXT_PUBLIC_API_KEY:-}
        NEXT_PUBLIC_CLIENT_ID: ${NEXT_PUBLIC_CLIENT_ID:-healthai-admin-front}
        NEXT_PUBLIC_FASTAPI_URL: http://localhost:8000
        NEXT_PUBLIC_METABASE_URL: http://localhost:3002
    image: healthai-admin:local
    ports:
      - "3000:3000"

  # healthai-web:
  #   build:
  #     context: ../healthai-web
  #     dockerfile: Dockerfile
  #   image: healthai-web:local
  #   ports:
  #     - "3001:3000"
