# reverse-proxy/Caddyfile
# ==============================================================================
# Caddy reverse proxy configuration
#
# Caddy provisionne automatiquement les certificats TLS via Let's Encrypt.
# Remplacer les hostnames ci-dessous par tes vrais noms de domaine.
# Pour le dev local, utiliser http:// sans nom de domaine.
# ==============================================================================

# Dashboard admin CRUD — healthai-admin
admin.example.com {
    reverse_proxy healthai-admin:3000
}

# Portail client — healthai-web (M3+)
app.example.com {
    reverse_proxy healthai-web:3000
}

# Backend API — healthai-api
api.example.com {
    reverse_proxy healthai-api:3001
}

# ETL upload endpoint — healthai-etl
etl.example.com {
    reverse_proxy healthai-etl:8000
}

# Identity provider — ZITADEL
auth.example.com {
    reverse_proxy zitadel:8080
}

# Gateway IA — healthai-ai-gateway (vision + workout)
ai.example.com {
    reverse_proxy healthai-ai-gateway:8000
}
