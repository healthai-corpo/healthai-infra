# ==============================================================================
# .env.example — copier en .env et remplir les valeurs
# Ne jamais commiter le vrai .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Tags des images GHCR
# ------------------------------------------------------------------------------
API_TAG=latest
ETL_TAG=latest
ADMIN_TAG=latest
WEB_TAG=latest

# ------------------------------------------------------------------------------
# PostgreSQL — base ZITADEL
# Générer : openssl rand -base64 32
# ------------------------------------------------------------------------------
POSTGRES_ZITADEL_PASSWORD=change_me_zitadel_db_password

# ------------------------------------------------------------------------------
# ZITADEL — clé maître (min 32 caractères)
# Générer : openssl rand -base64 32
# ------------------------------------------------------------------------------
ZITADEL_MASTERKEY=change_me_replace_with_openssl_rand_output

# Host public de ZITADEL (pour les redirects OAuth)
# En dev local : localhost | En prod : auth.example.com
ZITADEL_HOST=localhost

# ------------------------------------------------------------------------------
# PostgreSQL — base applicative HealthAI
# Générer : openssl rand -base64 32
# ------------------------------------------------------------------------------
POSTGRES_USER=healthai
POSTGRES_PASSWORD=change_me_app_db_password
POSTGRES_DB=healthai_db

# ------------------------------------------------------------------------------
# URLs publiques (accessibles depuis le navigateur)
# En dev local : http://localhost:PORT | En prod : https://domaine.com
# ------------------------------------------------------------------------------
PUBLIC_API_URL=http://localhost:3001
PUBLIC_ZITADEL_URL=http://localhost:8080
PUBLIC_ETL_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# ZITADEL — credentials M2M pour healthai-etl (service account)
# Créer un service account dans la console ZITADEL et copier les valeurs
# ------------------------------------------------------------------------------
ETL_CLIENT_ID=change_me_etl_client_id
ETL_CLIENT_SECRET=change_me_etl_client_secret
