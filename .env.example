# ==============================================================================
# .env.example — copy this file to .env and fill in your values
# Never commit your real .env to version control
# ==============================================================================

# ------------------------------------------------------------------------------
# Image tags — set to the desired release tag for each service
# Use "latest" for testing; pin to a specific tag in production
# ------------------------------------------------------------------------------
API_TAG=latest
ETL_TAG=latest
WEB_TAG=latest

# ------------------------------------------------------------------------------
# PostgreSQL — password for the ZITADEL database user
# Generate with: openssl rand -base64 32
# ------------------------------------------------------------------------------
POSTGRES_PASSWORD=change_me_postgres_password

# ------------------------------------------------------------------------------
# ZITADEL master key — must be exactly 32 bytes (256-bit)
# Generate with: openssl rand -base64 32
# ------------------------------------------------------------------------------
ZITADEL_MASTERKEY=change_me_masterkey_32_bytes_min

# ------------------------------------------------------------------------------
# ZITADEL machine-to-machine credentials for healthai-etl
# Create a service account in the ZITADEL console and copy its client ID/secret
# ------------------------------------------------------------------------------
ETL_CLIENT_ID=change_me_etl_client_id
ETL_CLIENT_SECRET=change_me_etl_client_secret
