# ==============================================================================
# .env.example — copy this file to .env and fill in your values
# Never commit your real .env to version control
# ==============================================================================

# ------------------------------------------------------------------------------
# Image tags — set to the desired release tag for each service
# Use "latest" for testing; pin to a specific tag in production
# ------------------------------------------------------------------------------
API_TAG=latest
ETL_TAG=latest
WEB_TAG=latest

# ------------------------------------------------------------------------------
# PostgreSQL — password for the ZITADEL database user
# Generate with: openssl rand -base64 32
# ------------------------------------------------------------------------------
POSTGRES_PASSWORD=change_me_postgres_password

# ------------------------------------------------------------------------------
# ZITADEL master key — used to encrypt sensitive data at rest.
# Must be at least 32 characters long.
# Generate a suitable value with: openssl rand -base64 32
# (produces 44 printable characters encoding 32 random bytes)
# ------------------------------------------------------------------------------
ZITADEL_MASTERKEY=change_me_replace_with_openssl_rand_output

# ------------------------------------------------------------------------------
# Public-facing URLs — used by the browser (NEXT_PUBLIC_* vars are baked into
# the client-side JS bundle, so they must be reachable from users' browsers).
# In production, set these to your actual domain names.
# ------------------------------------------------------------------------------
PUBLIC_API_URL=http://localhost:5000
PUBLIC_ZITADEL_URL=http://localhost:8080

# ------------------------------------------------------------------------------
# ZITADEL machine-to-machine credentials for healthai-etl
# Create a service account in the ZITADEL console and copy its client ID/secret
# ------------------------------------------------------------------------------
ETL_CLIENT_ID=change_me_etl_client_id
ETL_CLIENT_SECRET=change_me_etl_client_secret

# ------------------------------------------------------------------------------
# ETL-specific configuration
# Database password for ETL access (can be different from ZITADEL password)
# Exercise database API key for fetching exercise data
# ------------------------------------------------------------------------------
ETL_DB_PASSWORD=change_me_etl_db_password
EXERCISE_DB_API_KEY=change_me_exercise_db_api_key
