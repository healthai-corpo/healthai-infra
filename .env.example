# ==============================================================================
# HealthAI — Global Environment Configuration
# ==============================================================================

# --- Versions des Images (Tags GHCR) ---
API_TAG=latest
ETL_TAG=latest
ADMIN_TAG=latest
AI_GATEWAY_TAG=latest
VISION_TAG=latest
WORKOUT_TAG=latest

# --- Configuration Réseau Globale (URLs Publiques) ---
ZITADEL_EXTERNAL_URL=http://localhost:8080
PUBLIC_API_URL=http://localhost:3001
PUBLIC_ETL_URL=http://localhost:8000
PUBLIC_ADMIN_URL=http://localhost:3000
PUBLIC_METABASE_URL=http://localhost:3002

# --- Gestion des Identités (ZITADEL) ---
POSTGRES_ZITADEL_PASSWORD=change_me_zitadel_db_password
ZITADEL_MASTERKEY=change_me_exactly_32_chars_xxxxxxxx
ZITADEL_HOST=localhost

# Domaine Zitadel INTERNE au réseau Docker pour le NestJS 
ZITADEL_DOMAIN=http://zitadel:8080

# --- Base de Données Métier (PostgreSQL) ---
POSTGRES_USER=healthai
POSTGRES_PASSWORD=change_me_app_db_password
POSTGRES_DB=healthai_db

# --- Base de Données NoSQL (MongoDB) ---
MONGO_USER=healthai
MONGO_PASSWORD=change_me_mongo_password

# --- Sécurité & Clés d'API (Générer avec openssl rand -hex 32) ---
API_KEY=change_me_min_32_chars_hex_string_here_xx
JWT_SECRET=change_me_min_32_chars_jwt_secret_here_xx
JWT_EXPIRES_IN=3600s
AUTH_SECRET=change_me_replace_with_openssl_rand_base64

# --- Enregistrement Applications Zitadel ---
ADMIN_ZITADEL_CLIENT_ID=change_me_admin_client_id
ADMIN_ZITADEL_CLIENT_SECRET=change_me_admin_client_secret
ETL_CLIENT_ID=change_me_etl_client_id
ETL_CLIENT_SECRET=change_me_etl_client_secret

# --- Configuration Intelligence Artificielle ---
AI_AUTH_MODE=jwks
AI_REQUIRED_ROLE=
OLLAMA_MODEL_VISION=qwen2.5:0.5b 
OLLAMA_MODEL_WORKOUT=llama3.2:3b
HF_MODEL_NAME=yolov8n.pt

# --- Intégrations Tierces & Analytics ---
METABASE_SECRET_KEY=change_me_metabase_secret_key
ETL_DB_PASSWORD=change_me_etl_db_password
EXERCISE_DB_API_KEY=change_me_exercise_db_api_key