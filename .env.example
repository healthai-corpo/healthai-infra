# ==============================================================================
# .env.example — copier en .env et remplir les valeurs
# Ne jamais commiter le vrai .env
# Générer les secrets : openssl rand -hex 32
# ==============================================================================

# ------------------------------------------------------------------------------
# Tags des images GHCR (laisser "latest" en dev)
# ------------------------------------------------------------------------------
API_TAG=latest
ETL_TAG=latest
ADMIN_TAG=latest
WEB_TAG=latest
AI_GATEWAY_TAG=latest
VISION_TAG=latest
WORKOUT_TAG=latest

# ------------------------------------------------------------------------------
# PostgreSQL — base ZITADEL
# ------------------------------------------------------------------------------
POSTGRES_ZITADEL_PASSWORD=change_me_zitadel_db_password

# ------------------------------------------------------------------------------
# ZITADEL — clé maître (exactement 32 bytes base64)
# Générer : openssl rand -base64 32
# ------------------------------------------------------------------------------
# Doit faire exactement 32 caractères (pas base64 — hex ou ASCII direct)
# Générer : node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ZITADEL_MASTERKEY=change_me_exactly_32_chars_xxxxxxxx

# Host public de ZITADEL (pour les redirects OAuth)
# En dev local : localhost | En prod : auth.mondomaine.com
ZITADEL_HOST=localhost

# ------------------------------------------------------------------------------
# PostgreSQL — base applicative HealthAI
# ------------------------------------------------------------------------------
POSTGRES_USER=healthai
POSTGRES_PASSWORD=change_me_app_db_password
POSTGRES_DB=healthai_db

# ------------------------------------------------------------------------------
# MongoDB — historique / traces des services IA (vision, workout)
# Générer le mot de passe : openssl rand -hex 32
# Les services IA se connectent via :
#   mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongo:27017/?authSource=admin
# ------------------------------------------------------------------------------
MONGO_USER=healthai
MONGO_PASSWORD=change_me_mongo_password

# ------------------------------------------------------------------------------
# RabbitMQ — bus de messages entre le front et les backends (API, IA, ETL)
# Management UI : http://localhost:15672 (même user/pass)
# Générer le mot de passe : openssl rand -hex 32
# URL complète injectée dans chaque service :
#   amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672/healthai
# ------------------------------------------------------------------------------
RABBITMQ_USER=healthai
RABBITMQ_PASSWORD=change_me_rabbitmq_password

# ------------------------------------------------------------------------------
# Services IA (gateway + vision + workout + Ollama)
# ------------------------------------------------------------------------------
# Mode auth du gateway IA :
#   - "jwks"     : valide l'access token Zitadel (JWKS) + email via userinfo (prod)
#   - "id_token" : valide un ID token Zitadel (email lu dans le claim) — transition
#   - "dev_stub" : court-circuite l'auth (id_utilisateur=1) — pour dev sans Zitadel
AI_AUTH_MODE=jwks

# Issuer Zitadel attendu par le gateway IA. DOIT valoir l'URL EXTERNE de Zitadel
# (= le claim `iss` du token), pas le nom interne docker, sinon "Invalid issuer".
# Cette meme URL sert a fetch JWKS + userinfo : le container l'atteint via le
# mapping extra_hosts (localhost -> host) declare sur healthai-ai-gateway.
# Laisser vide = defaut http://localhost:8080.
ZITADEL_ISSUER=http://localhost:8080

# Audience JWT attendue par le gateway IA.
# Laisser VIDE pour reutiliser ADMIN_ZITADEL_CLIENT_ID (même app que l'admin :
# un seul token Zitadel donne acces au backend ET aux services IA).
AI_JWT_AUDIENCE=

# Role projet Zitadel exige (vide = juste authentification).
# Si pas de role 'ai-user' dans Zitadel, laisse vide.
AI_REQUIRED_ROLE=

# LLM Ollama + YOLO (modeles pulls automatiquement)
OLLAMA_MODEL=llama3.2:3b
HF_MODEL_NAME=yolov8n.pt

# ------------------------------------------------------------------------------
# Sécurité API NestJS
# Générer : openssl rand -hex 32
# ------------------------------------------------------------------------------
API_KEY=change_me_min_32_chars_hex_string_here_xx

# JWT — authentification NestJS
# Générer JWT_SECRET : openssl rand -hex 32
JWT_SECRET=change_me_min_32_chars_jwt_secret_here_xx
JWT_EXPIRES_IN=3600s
JWT_ISSUER=healthai-api
JWT_AUDIENCE=healthai-web

# Domaine Zitadel INTERNE utilise par le NestJS pour recuperer les cles JWKS
# (cote serveur, reseau docker). Distinct de JWT_ISSUER (claim `iss`, URL externe).
# Laisser vide = defaut http://zitadel:8080.
ZITADEL_DOMAIN=http://zitadel:8080

# Origin du frontend admin (CORS)
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_CLIENT_ID=healthai-admin-front

# ------------------------------------------------------------------------------
# next-auth (healthai-admin)
# Générer : openssl rand -base64 32
# ------------------------------------------------------------------------------
AUTH_SECRET=change_me_replace_with_openssl_rand_output

# Application ZITADEL de type "Web" pour l'admin
# Créer dans ZITADEL > Projets > HealthAI > Applications > New App (Web)
# Redirect URI : http://localhost:3000/api/auth/callback/zitadel
ADMIN_ZITADEL_CLIENT_ID=change_me_admin_client_id
ADMIN_ZITADEL_CLIENT_SECRET=change_me_admin_client_secret

# ------------------------------------------------------------------------------
# URLs publiques (accessibles depuis le navigateur)
# ------------------------------------------------------------------------------
PUBLIC_API_URL=http://localhost:3001
PUBLIC_ZITADEL_URL=http://localhost:8080
PUBLIC_ETL_URL=http://localhost:8000
PUBLIC_ADMIN_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# ZITADEL — credentials M2M pour healthai-etl (service account)
# Créer dans ZITADEL > Service Users
# ------------------------------------------------------------------------------
ETL_CLIENT_ID=change_me_etl_client_id
ETL_CLIENT_SECRET=change_me_etl_client_secret

# ------------------------------------------------------------------------------
# ETL-specific configuration
# Database password for ETL access (can be different from ZITADEL password)
# Exercise database API key for fetching exercise data
# ------------------------------------------------------------------------------
ETL_DB_PASSWORD=change_me_etl_db_password
EXERCISE_DB_API_KEY=change_me_exercise_db_api_key
