    {
      "id": 1,
      "type": "alertlist",
      "title": "Alertes en cours (Firing / Pending)",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "options": {
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 50,
        "sortOrder": 1,
        "stateFilter": {
          "firing": true,
          "pending": true,
          "noData": false,
          "normal": false,
          "error": true
        },
        "viewMode": "list"
      }
    }
  ]
